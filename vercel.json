{
  "version": 3,
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@4"
    }
  },
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
